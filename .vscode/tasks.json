{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Grand-Duc Proxy",
            "type": "shell",
            "command": "cd target/debug ; ./grand-duc-proxy.exe",
            "dependsOn": ["Rebuild Proxy & restart"],
            "presentation": { "group": "demarrage-complet" }
        },
        {
            "label": "Frontend Vue.JS",
            "type": "shell",
            "command": "cd grand-duc-admin/frontend ; npm run dev",
            "presentation": { "group": "demarrage-complet" }
        },
        {
            "label": "Backend Python",
            "type": "shell",
            "command": "cd grand-duc-admin/backend ; ./venv/Scripts/activate ; uvicorn main:app --reload --port 8000",
            "presentation": { "group": "demarrage-complet" }
        },
        {
            "label": "DEMARRER TOUT",
            "dependsAll": true,
            "dependsOn": [
                "Grand-Duc Proxy",
                "Frontend Vue.JS",
                "Backend Python"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }, 
        
        {
            "label": "Rebuild Proxy & restart",
            "type": "shell",
            "command": "cd D:/Bureau/grand-duc ; cargo build ; cd target/debug ; ./grand-duc-proxy.exe",
            "group": "build"
        },
    ]
}