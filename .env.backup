# ── Grand-Duc Docker ──────────────────────────────────────────────────────────
# Copier ce fichier en .env pour docker-compose

# Mot de passe PostgreSQL
DB_PASSWORD=root

# Clé secrète JWT (à changer en production !)
SECRET_KEY=changez_cette_cle_en_production

# Port de l'interface d'administration (frontend)
ADMIN_PORT=80

# Port du proxy HTTP/HTTPS
PROXY_PORT=8080

# CORS origin pour le backend
ADMIN_CORS_ORIGIN=http://localhost

# Taille max du fichier de log proxy (100 Mo)
LOG_MAX_BYTES=104857600

# Niveau de log du proxy Rust
RUST_LOG=grand_duc=info,warn
